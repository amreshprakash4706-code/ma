# Lumina Real Estate SaaS - Environment Variables
# Copy this file to .env.local and fill in your values

# Database (PostgreSQL recommended for production)
DATABASE_URL="postgresql://username:password@localhost:5432/lumina?schema=public"

# JWT Secret for authentication
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production-min-32-chars"

# Google OAuth (for Google Sign-In)
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OpenAI for AI features (chatbot, descriptions, valuation, recommendations)
OPENAI_API_KEY="sk-your-openai-api-key-here"

# Resend for transactional emails (recommended over Nodemailer)
RESEND_API_KEY="re_your-resend-api-key"

# Cloudinary for image uploads
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# Stripe for payments (subscriptions, featured listings, etc.)
STRIPE_SECRET_KEY="sk_test_your-stripe-secret-key"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable-key"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# Google Maps API
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-api-key"

# App URL
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin seed credentials (for initial admin user)
ADMIN_EMAIL="admin@lumina.com"
ADMIN_PASSWORD="ChangeMe123!Secure"

# Optional: Recaptcha for forms (security)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY="your-recaptcha-site-key"
RECAPTCHA_SECRET_KEY="your-recaptcha-secret-key"
